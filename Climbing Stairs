Brute approach:
class Solution {
public:
    int climbStairs(int n) {
        if(n==0) return 1;
        if(n==1) return 1;
        vector<int > dp(n+1, -1);//Initalize

        if(dp[n]!=-1) return dp[n];//return if present

       int left = climbStairs(n-1);
       int right= climbStairs(n-2);

       return dp[n]=left + right;//store if not present

    }
};

