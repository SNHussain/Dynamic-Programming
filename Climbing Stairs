Tabulation(Bottom Up):
class Solution {
public:
    int climbStairs(int n) {
        if(n==0) return 1;
        if(n==1) return 1;
        vector<int > dp(n+1, 0);

       dp[0]=1;
       dp[1]=1;

        for(int i=2; i<=n; i++){
            dp[i]= climbStairs(n-1) +  climbStairs(n-2);
        }
       

       return dp[n];

    }
};

Space Optimzed- Tabulation:
class Solution {
public:
    int climbStairs(int n) {
        if(n==0) return 1;
        if(n==1) return 1;
        vector<int > dp(n+1, 0);

        int prev2=1; //dp[0]
        int prev=1; //dp[1]

        for(int i=2; i<=n; i++){
            int curr= prev2 + prev; //dp[i]
            prev2 = prev;
            prev = curr;
        }
       

       return prev;

    }
};
